APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Use `reverb` for self-hosted Laravel Reverb (recommended). Both `reverb` and
# `pusher` broadcast drivers require the PHP package `pusher/pusher-php-server`
# (Laravel builds a Pusher-protocol client for Reverb as well).
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

MEDIA_CDN_URL=
MEDIA_SIGNED_EXPIRATION_MINUTES=10

VITE_APP_NAME="${APP_NAME}"
VITE_BROADCAST_CONNECTION="${BROADCAST_CONNECTION}"

REVERB_APP_ID=app-id
REVERB_APP_KEY=app-key
REVERB_APP_SECRET=app-secret
# Where Laravel publishes broadcasts (Pusher HTTP API). Local PHP + `reverb:start`: 127.0.0.1.
# Docker (app container → reverb service): set REVERB_HOST=reverb (Compose service name).
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http
# Socket bind address for `php artisan reverb:start` (0.0.0.0 required to publish port from Docker).
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
# Host header Reverb accepts for WebSockets (browser hostname only — no scheme). Not REVERB_HOST.
# Example local: al-injaz.test. If unset, host is parsed from APP_URL.
REVERB_SERVER_HOSTNAME=al-injaz.test

# Browser-visible WebSocket endpoint (Echo). Optional: when unset, the app falls back to request host/port.
# Docker + Nginx proxy: keep REVERB_HOST=reverb for PHP, then point the browser at your APP_URL host on port 80.
# Laravel shares these via Inertia so Echo does not depend on stale VITE_* builds.
# REVERB_PUBLIC_HOST=al-injaz.test
# REVERB_PUBLIC_PORT=80
# REVERB_PUBLIC_SCHEME=http

# Fallback for `npm run dev` / build (Inertia `reverb` prop overrides at runtime when broadcasting=reverb).
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Optional: only when BROADCAST_CONNECTION=pusher (Pusher.com / compatible host)
# PUSHER_APP_ID=
# PUSHER_APP_KEY=
# PUSHER_APP_SECRET=
# PUSHER_APP_CLUSTER=mt1
# PUSHER_HOST=
# PUSHER_PORT=443
# PUSHER_SCHEME=https

# ─── Notification Configuration (Phase 4.5) ─────────────────────────────
# When true, `outbox:process` will dispatch selected outbox events through
# the new notification engine (engine-only; legacy is expected to be
# suppressed by outbox gating + engine duplicate prevention).
NOTIFICATION_ENGINE_OUTBOX_DISPATCH_ENABLED=false
NOTIFICATION_ENGINE_OUTBOX_DISPATCH_EVENT_KEYS=

# Task notifications (Phase 6)
# Controls how many days ahead a task is considered "due soon".
TASK_DUE_SOON_WARNING_DAYS=7

# Controls whether the system sends internal overdue reminders for tasks.
# Can be overridden in DB via SystemSetting `task_overdue_reminders_enabled`.
TASK_OVERDUE_REMINDERS_ENABLED=1
