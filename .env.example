# ═══════════════════════════════════════════════════════════════════════════
# Al Injaz — environment template (copy to .env; never commit real .env)
# ═══════════════════════════════════════════════════════════════════════════
#
# SENSITIVE (rotate in production, never log):
#   APP_KEY, DB_PASSWORD, REDIS_PASSWORD, AWS_* keys, REVERB_APP_SECRET,
#   MAIL_PASSWORD, EVOLUTION_API_KEY, any API tokens
#
# ═══════════════════════════════════════════════════════════════════════════

APP_NAME="Al Injaz"
APP_ENV=local
# Generate: php artisan key:generate  (SENSITIVE — unique per environment)
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Production: APP_ENV=production, APP_DEBUG=false, APP_URL=https://your-domain.tld

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ─── Logging ────────────────────────────────────────────────────────────────
# Production: LOG_CHANNEL=stack, LOG_LEVEL=error (or warning)
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Optional error tracking (requires sentry/sentry-laravel or similar — verify composer before installing)
# SENTRY_LARAVEL_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── Database (PostgreSQL required for production) ─────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=al_injaz
DB_USERNAME=al_injaz
# SENSITIVE
DB_PASSWORD=

# ─── Session (production: secure cookies behind HTTPS) ─────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Production behind HTTPS: true (or leave unset — Laravel infers from request when null)
SESSION_SECURE_COOKIE=
SESSION_HTTP_ONLY=true
# Production: strict or lax (strict may affect OAuth/deep links — test first)
SESSION_SAME_SITE=lax

# ─── Redis (cache, queue, sessions, Horizon) ────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
# SENSITIVE if set
REDIS_PASSWORD=null
REDIS_PORT=6379

# Production: must be redis (not array/database for multi-worker)
CACHE_STORE=redis
# CACHE_PREFIX=

QUEUE_CONNECTION=redis

MEMCACHED_HOST=127.0.0.1

# ─── Broadcasting / Laravel Reverb ─────────────────────────────────────────
# Use `reverb` for self-hosted. PHP needs pusher/pusher-php-server.
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=
REVERB_APP_KEY=
# SENSITIVE
REVERB_APP_SECRET=
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
REVERB_SERVER_HOSTNAME=
REVERB_PUBLIC_HOST=
REVERB_PUBLIC_PORT=
REVERB_PUBLIC_SCHEME=

VITE_APP_NAME="${APP_NAME}"
VITE_BROADCAST_CONNECTION="${BROADCAST_CONNECTION}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Optional: Pusher.com (when BROADCAST_CONNECTION=pusher)
# PUSHER_APP_ID=
# PUSHER_APP_KEY=
# PUSHER_APP_SECRET=
# PUSHER_APP_CLUSTER=mt1

# ─── Files / S3-compatible (MinIO dev, AWS S3 production) ─────────────────────
FILESYSTEM_DISK=local
# Spatie Media Library disk for Task / TaskComment attachments (and default when collection does not override).
# Local dev without MinIO: public (storage/app/public). Production / MinIO: s3 (set AWS_* below).
MEDIA_DISK=public
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=me-south-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

MEDIA_CDN_URL=
MEDIA_SIGNED_EXPIRATION_MINUTES=10

# ─── Mail ───────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── CORS (never use * with credentials) ─────────────────────────────────────
# Comma-separated exact origins, e.g. https://app.example.com
CORS_ALLOWED_ORIGINS=

# ─── Security headers / CSP (see config/security.php) ────────────────────────
SECURITY_HEADERS_ENABLED=true
SECURITY_CSP_ENABLED=false
SECURITY_CSP_REPORT_ONLY=true

# ─── Trusted proxies (behind AWS ELB / Cloudflare / Nginx) ───────────────────
# TRUSTED_PROXIES=*

# ─── Laravel Horizon ─────────────────────────────────────────────────────────
HORIZON_NAME="${APP_NAME}"
# HORIZON_DOMAIN=
HORIZON_PATH=horizon
# HORIZON_PREFIX=
# Ops email for Horizon alerts (long queue waits, etc.) — see config/horizon.php `waits`
# HORIZON_NOTIFICATION_EMAIL=

# ─── Deep health check GET /health (optional Horizon / Reverb probes) ───────
# HEALTH_CHECK_HORIZON=false
# HEALTH_CHECK_REVERB=false
# HEALTH_REVERB_URL=http://reverb:8080

# ─── Notification engine / tasks ─────────────────────────────────────────────
# Master switch for the Phase 2 notification engine (see config/notifications.php).
# NOTIFICATION_ENGINE_ENABLED=false
#
# Pilot: when NOTIFICATION_ENGINE_PILOT_ENABLED=true, only keys listed in
# NOTIFICATION_ENGINE_PILOT_EVENT_KEYS are routed through the new engine (legacy otherwise),
# unless you use wildcard mode:
#   NOTIFICATION_ENGINE_PILOT_EVENT_KEYS=*
# The literal * means ALL event keys use the engine while pilot is on (opt-in; not the default).
# You can combine with NOTIFICATION_ENGINE_ENABLED=true for local/staging full rollout tests.
# Example full pilot for one environment:
#   NOTIFICATION_ENGINE_ENABLED=true
#   NOTIFICATION_ENGINE_PILOT_ENABLED=true
#   NOTIFICATION_ENGINE_PILOT_EVENT_KEYS=*
#
NOTIFICATION_ENGINE_OUTBOX_DISPATCH_ENABLED=false
NOTIFICATION_ENGINE_OUTBOX_DISPATCH_EVENT_KEYS=
TASK_DUE_SOON_WARNING_DAYS=7
TASK_OVERDUE_REMINDERS_ENABLED=1

# ─── WhatsApp (Evolution API) ────────────────────────────────────────────────
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_API_SECRET=
EVOLUTION_API_INSTANCE=
